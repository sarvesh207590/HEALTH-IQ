# HealthIQ - Environment Variables Template
# Copy this file to .env and fill in your actual values

# ============================================
# REQUIRED - Core Services (Must have for deployment)
# ============================================

# Database - MongoDB Atlas connection string
DATABASE_URL="mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority"

# Authentication - Generate a secure random string (use: openssl rand -base64 32)
NEXTAUTH_SECRET="generate-a-random-secret-here-use-openssl-rand-base64-32"

# AI Analysis - OpenAI API key for medical image analysis
OPENAI_API_KEY="sk-proj-your-openai-api-key"

# ============================================
# OPTIONAL - OAuth Providers (Only if using Google login)
# ============================================
# GOOGLE_CLIENT_ID="your-google-client-id"
# GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ============================================
# AUTO-GENERATED by Vercel (Don't add these manually)
# ============================================
# NEXTAUTH_URL - Automatically set to your Vercel deployment URL
# NEXT_PUBLIC_APP_URL - Automatically set to your Vercel deployment URL
# NODE_ENV - Automatically set to "production"
