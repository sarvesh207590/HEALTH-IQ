# Production Environment Variables
# These will be overridden by Vercel environment variables

# App Configuration
NODE_ENV="production"
NEXT_PUBLIC_APP_URL="${VERCEL_URL}"
NEXT_PUBLIC_SOCKET_URL="${VERCEL_URL}"

# Note: All sensitive variables (DATABASE_URL, NEXTAUTH_SECRET, OPENAI_API_KEY, etc.)
# should be set in Vercel Dashboard under Settings > Environment Variables
