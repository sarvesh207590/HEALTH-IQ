# Vercel Ignore - Files to exclude from deployment

# Development files
.env.local
.env.development
.env.test

# Testing
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx
__tests__/
coverage/

# Documentation (optional - remove if you want docs deployed)
*.md
!README.md

# Deployment documentation (local reference only)
DEPLOY_NOW.md
VERCEL_DEPLOYMENT_GUIDE.md
DEPLOYMENT_SUMMARY.md
DEPLOYMENT_FLOWCHART.md
README_DEPLOYMENT.md
pre-deploy-check.js

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Python files (from parent directory)
*.py
*.pyc
__pycache__/
venv/

# Temporary files
.tmp/
temp/
